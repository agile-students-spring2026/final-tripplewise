{
  "name": "tripplewise-backend",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "bash -c 'source ~/.nvm/nvm.sh && nvm use && nodemon index.js --watch . --ext js,json'",
    "test": "bash -c 'source ~/.nvm/nvm.sh && nvm use && mocha --exit --recursive'",
    "coverage": "bash -c 'source ~/.nvm/nvm.sh && nvm use && c8 --reporter=text --reporter=lcov npm test'",
    "prestart": "bash -c 'source ~/.nvm/nvm.sh && nvm use'"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "c8": "^7.13.0",
    "chai": "^4.3.7",
    "chai-http": "^4.3.0",
    "mocha": "^7.2.0",
    "nodemon": "^3.1.14",
    "supertest": "^6.3.3"
  }
}
